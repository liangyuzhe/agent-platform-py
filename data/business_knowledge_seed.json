[
  {
    "term": "净利润",
    "formula": "收入 - 成本 - 费用；净利润 > 0 表示盈利，净利润 < 0 表示亏损，净利润 = 0 表示不盈不亏；亏损金额 = CASE WHEN 净利润 < 0 THEN ABS(净利润) ELSE 0 END",
    "synonyms": "净收益, 盈利, 亏损, 净亏损, 赔钱, 赚钱, 亏损多少, 亏损金额, profit, loss",
    "related_tables": "t_journal_item,t_account,t_expense_claim"
  },
  {
    "term": "毛利率",
    "formula": "(SUM(credit_amount) - SUM(debit_amount)) / SUM(credit_amount) * 100 WHERE account_type='损益'",
    "synonyms": "gross margin, 毛利比率",
    "related_tables": "t_journal_item,t_account"
  },
  {
    "term": "净利率",
    "formula": "(收入 - 成本 - 费用) / 收入 * 100",
    "synonyms": "net margin, 净利润比率",
    "related_tables": "t_journal_item,t_account,t_expense_claim"
  },
  {
    "term": "预算执行率",
    "formula": "actual_amount / budget_amount * 100",
    "synonyms": "预算完成率, 执行进度, 执行比例",
    "related_tables": "t_budget"
  },
  {
    "term": "预算差异",
    "formula": "actual_amount - budget_amount",
    "synonyms": "预算偏差, 超支金额",
    "related_tables": "t_budget"
  },
  {
    "term": "资产负债率",
    "formula": "负债总额 / 资产总额 * 100",
    "synonyms": "负债率, 杠杆率",
    "related_tables": "t_account"
  },
  {
    "term": "应收账款周转率",
    "formula": "收入 / 平均应收账款",
    "synonyms": "应收周转, 回款效率",
    "related_tables": "t_receivable_payable,t_journal_item"
  },
  {
    "term": "应收逾期率",
    "formula": "逾期应收金额 / 应收总额 * 100",
    "synonyms": "逾期比例, 坏账率",
    "related_tables": "t_receivable_payable"
  },
  {
    "term": "费用总额",
    "formula": "SUM(total_amount) FROM t_expense_claim WHERE status IN ('已审批','已付款')",
    "synonyms": "总费用, 费用合计, 报销总额",
    "related_tables": "t_expense_claim"
  },
  {
    "term": "部门费用",
    "formula": "SUM(total_amount) GROUP BY cost_center_id",
    "synonyms": "各部门费用, 部门开销",
    "related_tables": "t_expense_claim,t_cost_center"
  },
  {
    "term": "凭证过账率",
    "formula": "COUNT(CASE WHEN status='已过账' THEN 1 END) / COUNT(*) * 100",
    "synonyms": "过账比例",
    "related_tables": "t_journal_entry"
  },
  {
    "term": "发票认证率",
    "formula": "COUNT(CASE WHEN verification_status='已认证' THEN 1 END) / COUNT(*) * 100 WHERE direction='进项'",
    "synonyms": "认证比例, 抵扣率",
    "related_tables": "t_invoice"
  },
  {
    "term": "资金划转频率",
    "formula": "COUNT(*) / 天数",
    "synonyms": "转账频次, 划款频率",
    "related_tables": "t_fund_transfer"
  },
  {
    "term": "固定资产净值率",
    "formula": "(acquisition_cost - accumulated_depreciation) / acquisition_cost * 100",
    "synonyms": "资产新旧程度",
    "related_tables": "t_fixed_asset"
  },
  {
    "term": "制证人工作量",
    "formula": "COUNT(*) GROUP BY prepared_by",
    "synonyms": "凭证制作量, 制单统计",
    "related_tables": "t_journal_entry"
  },
  {
    "term": "科目余额",
    "formula": "SUM(debit_amount) - SUM(credit_amount) GROUP BY account_code",
    "synonyms": "账户余额, 科目结余",
    "related_tables": "t_journal_item,t_account"
  }
]
